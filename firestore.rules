rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }
    
    function isAdmin() {
      return hasRole('Admin') || (isSignedIn() && request.auth.token.email == 'jobsdepina@gmail.com' && request.auth.token.email_verified == true);
    }
    
    function isDirector() {
      return hasRole('Director');
    }

    function isManager() {
      return hasRole('Farm Manager');
    }

    function isVet() {
      return hasRole('Veterinarian');
    }

    function isOperator() {
      return hasRole('Operator');
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // User Profiles
    match /profiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    // Farms
    match /farms/{farmId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Locations
    match /locations/{locId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isManager();
    }

    // Chicken Lots
    match /chicken_lots/{lotId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isManager();
    }

    // Egg Production
    match /egg_productions/{prodId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() || isManager() || isOperator();
      allow delete: if isAdmin() || isManager();
    }

    // Poultry Weight Records
    match /weight_records/{recId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() || isManager() || isOperator();
      allow delete: if isAdmin() || isManager();
    }

    // Animals (Ruminants)
    match /animals/{animalId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isManager() || isVet();
    }

    // Animal Weights
    match /animal_weights/{weightId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isManager() || isVet() || isOperator();
    }

    // Reproductions
    match /reproductions/{repId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isManager() || isVet();
    }

    // Lactation Cycles
    match /lactation_cycles/{lacId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isManager() || isVet();
    }

    // Milk Production
    match /milk_productions/{milkId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() || isManager() || isOperator();
      allow delete: if isAdmin() || isManager();
    }

    // Feeds
    match /feeds/{feedId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isManager();
    }

    // Silos
    match /silos/{siloId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isManager();
    }

    // Stock Movements
    match /stock_movements/{movId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isManager() || isOperator();
    }

    // Feed Consumption
    match /feed_consumptions/{consId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isManager() || isOperator();
    }

    // Inventories
    match /inventories/{invId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isManager() || isOperator();
    }

    // Health Records
    match /health_records/{recId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isManager() || isVet() || isOperator();
    }

    // Egg Inventory
    match /egg_inventory/{invId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isManager() || isOperator();
    }

    // Vaccinations
    match /vaccinations/{vacId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isManager() || isVet();
    }

    // Costs
    match /costs/{costId} {
      allow read: if isSignedIn() && (isAdmin() || isManager() || isDirector());
      allow write: if isAdmin() || isManager();
    }

    // Sales
    match /sales/{saleId} {
      allow read: if isSignedIn() && (isAdmin() || isManager() || isDirector() || isOperator());
      allow create, update: if isAdmin() || isManager() || isOperator();
      allow delete: if isAdmin() || isManager();
    }
  }
}
